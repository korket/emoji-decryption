# Copy this file to .env and adjust as needed.

# Server
PORT=3000
DB_PATH=./game.db
AUTO_START=false      # Start idle; set true to begin the game when the backend starts
CHAT_ENABLED=true     # Set false for local overlay testing without YouTube chat
YOUTUBE_MIN_POLL_MS=5000 # Minimum delay between live chat API polls (ms)

# Game settings
MAX_ROUNDS=10          # Rounds per session before showing final standings
PRE_GAME_MS=20000      # Pre-game countdown duration (ms)
INTER_ROUND_MS=10000   # Pause between rounds (ms)
RESTART_DELAY_MS=10000 # How long to show the session-end screen before restarting (ms)
